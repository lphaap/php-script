<?pscript
    $namespace1 = [];
    $namespace2 = [];

    $namespace1['hello_world'] = client hello1;
    $namespace2['hello_world'] = client hello2;
?>

client  {
    function hello1() {
        console.log("Hello world 1!");
    }

    function hello2() {
        console.log("Hello world 2!");
    }
}

client {
    $namespace1['hello_world']();
}

client {
    $namespace2['hello_world']();
}
